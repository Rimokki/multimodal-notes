// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  username     String?       @unique
  passwordHash String
  avatarUrl    String?
  isActive     Boolean       @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  notes        Note[]
  assets       NoteAsset[]
  sessions     UserSession[]

  @@index([createdAt])
}

model UserSession {
  id               String    @id @default(cuid())
  userId           Int
  refreshTokenHash String    @unique
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

enum AssetKind {
  IMAGE
  AUDIO
  FILE
}

enum AssetSourceType {
  UPLOAD
  EXTERNAL
}

enum AssetStatus {
  PENDING
  READY
  FAILED
}

model Note {
  id         Int      @id @default(autoincrement())
  userId     Int?
  owner      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  assets     NoteAsset[]
  title      String
  content    String   // Tiptap JSON string
  rawText    String?  // Plain text for search optimization
  isFavorite Boolean  @default(false)
  isDeleted  Boolean  @default(false)
  deletedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, updatedAt])
  @@index([userId, isDeleted, updatedAt])
  @@index([userId, isFavorite, updatedAt])
}

model NoteAsset {
  id         Int             @id @default(autoincrement())
  noteId     Int
  note       Note            @relation(fields: [noteId], references: [id], onDelete: Cascade)
  userId     Int
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind       AssetKind
  sourceType AssetSourceType @default(UPLOAD)
  storageKey String?
  url        String
  mimeType   String
  fileName   String?
  fileExt    String?
  sizeBytes  Int
  width      Int?
  height     Int?
  durationMs Int?
  checksum   String?
  ocrText    String?
  status     AssetStatus     @default(PENDING)
  sortOrder  Int             @default(0)
  deletedAt  DateTime?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([noteId, sortOrder])
  @@index([userId, createdAt])
  @@index([noteId, kind])
  @@index([status])
}
