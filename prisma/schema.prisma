// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  username     String?       @unique
  passwordHash String
  avatarUrl    String?
  isActive     Boolean       @default(true)
  role         UserRole      @default(USER)
  lastLoginAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  notes        Note[]
  assets       NoteAsset[]
  tags         Tag[]
  sessions     UserSession[]
  likes        Like[]
  favorites    Favorite[]
  adminLogs               AdminLog[]
  sentNotifications       Notification[]     @relation("SentNotifications")
  targetedNotifications   Notification[]
  notificationReads       NotificationRead[]

  @@index([createdAt])
}

model UserSession {
  id               String    @id @default(cuid())
  userId           Int
  refreshTokenHash String    @unique
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

enum AssetKind {
  IMAGE
  AUDIO
  FILE
}

enum AssetSourceType {
  UPLOAD
  EXTERNAL
}

enum AssetStatus {
  PENDING
  READY
  FAILED
}

enum UserRole {
  USER
  ADMIN
}

enum AdminAction {
  USER_UPDATE
  NOTE_DELETE
  PASSWORD_RESET
  NOTIFICATION_BROADCAST
  NOTIFICATION_DELETE
}

enum NotificationType {
  BROADCAST
  TARGETED
}

model Note {
  id         Int      @id @default(autoincrement())
  userId     Int?
  owner      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  assets     NoteAsset[]
  tags       NoteTag[]
  likes      Like[]
  favorites  Favorite[]
  title      String
  content    String   // Tiptap JSON string
  rawText    String?  // Plain text for search optimization
  isFavorite Boolean  @default(false)
  isDeleted  Boolean  @default(false)
  isPublic   Boolean  @default(false)
  deletedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, updatedAt])
  @@index([userId, isDeleted, updatedAt])
  @@index([userId, isFavorite, updatedAt])
  @@index([isPublic, updatedAt])
}

model Tag {
  id        Int       @id @default(autoincrement())
  userId    Int
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes     NoteTag[]

  @@unique([userId, name])
  @@index([userId])
}

model NoteTag {
  noteId    Int
  tagId     Int
  note      Note      @relation(fields: [noteId], references: [id], onDelete: Cascade)
  tag       Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@id([noteId, tagId])
  @@index([tagId])
}

model NoteAsset {
  id         Int             @id @default(autoincrement())
  noteId     Int
  note       Note            @relation(fields: [noteId], references: [id], onDelete: Cascade)
  userId     Int
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind       AssetKind
  sourceType AssetSourceType @default(UPLOAD)
  storageKey String?
  url        String
  mimeType   String
  fileName   String?
  fileExt    String?
  sizeBytes  Int
  width      Int?
  height     Int?
  durationMs Int?
  checksum   String?
  ocrText    String?
  status     AssetStatus     @default(PENDING)
  sortOrder  Int             @default(0)
  deletedAt  DateTime?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([noteId, sortOrder])
  @@index([userId, createdAt])
  @@index([noteId, kind])
  @@index([status])
}

model AdminLog {
  id        Int         @id @default(autoincrement())
  adminId   Int
  action    AdminAction
  targetId  Int?
  detail    String?
  ipAddress String?
  createdAt DateTime    @default(now())

  admin     User        @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([action])
  @@index([createdAt])
}

model Notification {
  id        Int              @id @default(autoincrement())
  type      NotificationType
  title     String
  content   String
  userId    Int?
  senderId  Int
  createdAt DateTime         @default(now())

  user      User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  sender    User             @relation("SentNotifications", fields: [senderId], references: [id])
  reads     NotificationRead[]

  @@index([userId, createdAt])
  @@index([type, createdAt])
  @@index([senderId])
}

model NotificationRead {
  id             Int          @id @default(autoincrement())
  notificationId Int
  userId         Int
  readAt         DateTime     @default(now())

  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@index([userId])
}

model Like {
  id        Int      @id @default(autoincrement())
  userId    Int
  noteId    Int
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@unique([userId, noteId])
  @@index([noteId])
}

model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  noteId    Int
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@unique([userId, noteId])
  @@index([noteId])
}
